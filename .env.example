# Supabase
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth (for Google Classroom API)
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URL (required for OAuth callbacks in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Must be mailto: or https:// URI
VAPID_SUBJECT=mailto:you@example.com

# Sentry error monitoring
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
# Safe as NEXT_PUBLIC_ — DSN only allows submitting events, not reading them
NEXT_PUBLIC_SENTRY_DSN=